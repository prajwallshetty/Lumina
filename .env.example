# ─────────────────────────────────────────────────────────────
# Lumina — Environment Variables
# Copy to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Lumina

# ── Database (PostgreSQL) ─────────────────────────────────────
# Supply your own connection string (Neon / Supabase / RDS / local).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/lumina?schema=public"
# Optional direct (non-pooled) connection for migrations on serverless DBs.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/lumina?schema=public"

# ── Better Auth ───────────────────────────────────────────────
# Generate a secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
BETTER_AUTH_URL=http://localhost:3000

# ── Cloudinary (media library) ────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_UPLOAD_FOLDER="lumina"

# ── SMTP (transactional email) ────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Lumina <no-reply@example.com>"

# ── Integrations (optional, also configurable via Settings CMS) ─
NEXT_PUBLIC_WHATSAPP_NUMBER=""
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""

# ── Security ──────────────────────────────────────────────────
# Comma-separated list of allowed origins for server actions / CORS.
ALLOWED_ORIGINS="http://localhost:3000"
